# GitHub OAuth App: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Must match the Authorization callback URL in the GitHub OAuth app (e.g. http://127.0.0.1:8000/auth/callback)
GITHUB_REDIRECT_URI=http://127.0.0.1:8000/auth/callback
# Random secret for session signing (e.g. openssl rand -hex 32)
SESSION_SECRET=
